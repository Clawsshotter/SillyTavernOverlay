{
    "manifest_version": 3,
    "name": "SillyTavernOverlay Connector",
    "version": "1.0",
    "description": "Connects SillyTavern to the desktop overlay app via WebSockets.",
    "content_scripts": [
        {
            "matches":[
                "http://127.0.0.1:8000/*", "http://localhost:8000/*"
            ],
            "js": ["content.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["injector.js"],
            "matches":[
                "http://127.0.0.1:8000/*", "http://localhost:8000/*"
            ]
        }
    ]
}